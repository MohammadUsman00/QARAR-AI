# Google Gemini (replaces Anthropic for this project)
GEMINI_API_KEY=
# Optional override — default is a fast JSON-capable model
GEMINI_MODEL=gemini-2.0-flash

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (optional in the free build — leave empty until you are ready)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ELITE_MONTHLY=

# Email (optional — wire Resend in webhooks / notifications)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
